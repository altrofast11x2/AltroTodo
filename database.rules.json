{
  "rules": {
    ".read": false,
    ".write": false,
    "posts": {
      ".read": true,
      ".write": "auth != null || true",
      ".indexOn": ["authorId", "createdAt", "category"]
    },
    "comments":        { ".read": true,  ".write": true },
    "likes":           { ".read": true,  ".write": true },
    "stories":         { ".read": true,  ".write": true },
    "shorts":          { ".read": true,  ".write": true },
    "shorts_comments": { ".read": true,  ".write": true },
    "follows":         { ".read": true,  ".write": true },
    "study":           { ".read": true,  ".write": true },
    "chatRooms":       { ".read": true,  ".write": true },
    "chatMessages":    { ".read": true,  ".write": true },
    "keepalive":       { ".read": false, ".write": true },
    "users": {
      ".indexOn": ["email"],
      ".read": true,
      ".write": true
    },
    "poker_rooms":     { ".read": true,  ".write": true },
    "poker_visitors":  { ".read": false, ".write": true },
    "chess_queue":     { ".read": true,  ".write": true },
    "chess_matches":   { ".read": true,  ".write": true },
    "chess_ratings":   { ".read": true,  ".write": true },
    "agar":            { ".read": true,  ".write": true },
    "slither":         { ".read": true,  ".write": true },
    "diep":            { ".read": true,  ".write": true },
    "galleries":       { ".read": true,  ".write": true },
    "reports":         { ".read": true,  ".write": true },
    "verifyRequests":  { ".read": true,  ".write": true },
    "saved_posts":         { ".read": true,  ".write": true },
    "messages_seen":       { ".read": true,  ".write": true },
    "chess_resigns":       { ".read": true,  ".write": true },
    "cheat_reports":       { ".read": true,  ".write": true },
    "cheat_reports_index": { ".read": true,  ".write": true },

    "shop_users": {
      ".read": true,
      ".write": true,
      ".indexOn": ["email", "createdAt"]
    },
    "shop_products": {
      ".read": true,
      ".write": true,
      ".indexOn": ["createdAt", "sellerId"]
    },
    "shop_comments": { ".read": true, ".write": true },
    "shop_carts":    { ".read": true, ".write": true },
    "shop_orders": {
      ".read": true,
      ".write": true,
      ".indexOn": ["date", "userId"]
    },
    "shop_coin_requests": {
      ".read": true,
      ".write": true,
      ".indexOn": ["createdAt", "userId", "status"]
    },
    "shop_reports": {
      ".read": true,
      ".write": true,
      ".indexOn": ["createdAt", "status"]
    },

    "todo_users": {
      ".read": true,
      ".write": true,
      ".indexOn": ["email", "createdAt"]
    },
    "todo_items": {
      "$uid": {
        ".read": true,
        ".write": true,
        ".indexOn": ["done", "dueDate", "createdAt", "categoryId", "completedAt"]
      }
    },
    "todo_categories": {
      "$uid": {
        ".read": true,
        ".write": true,
        ".indexOn": ["createdAt"]
      }
    },
    "todo_settings": {
      ".read": true,
      ".write": true
    }
  }
}
